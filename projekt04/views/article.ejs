<%- include('partials/head') %>
<main>
  <% if (user && user.role === 'admin') { %>
    <section style="background: #eee; padding: 15px; border: 2px dashed #333; margin-bottom: 20px; color: #000;">
      <h4>Edytuj Artykuł (Admin)</h4>
      <form action="/articles/<%= article.article_id %>/edit" method="POST">
        <input type="text" name="title" value="<%= article.title %>" required minlength="3">
        <textarea name="content" required minlength="10" rows="5"><%= article.content %></textarea>
        <button type="submit">Zapisz zmiany w artykule</button>
      </form>
    </section>
  <% } %>

  <article>
    <h2><%= article.title %></h2>
    <p><%= article.content %></p>
  </article>

  <hr>
  <h3>Komentarze</h3>
  <% article.comments.forEach(comment => { %>
    <div class="comment">
      <p><strong><%= comment.name %>:</strong> <%= comment.text %></p>
      <% if (user && (user.role === 'admin' || user.id === comment.user_id)) { %>
        <form action="/comments/<%= comment.comment_id %>/delete" method="POST" style="display:inline;">
          <input type="hidden" name="articleId" value="<%= article.article_id %>">
          <button type="submit" onclick="return confirm('Usunąć komentarz?')">Usuń</button>
        </form>
      <% } %>
    </div>
  <% }) %>

  <% if (user) { %>
    <section style="margin-top: 20px;">
      <h4>Dodaj komentarz jako <%= user.username %></h4>
      <form action="/articles/<%= article.article_id %>/comments" method="POST">
        <textarea name="text" placeholder="Wpisz treść komentarza..." required minlength="2"></textarea>
        <button type="submit">Wyślij</button>
      </form>
    </section>
  <% } else { %>
    <p><a href="/login">Zaloguj się</a>, aby dodać komentarz.</p>
  <% } %>
  <p><a href="/">← Powrót do listy</a></p>
</main>
<%- include('partials/foot') %>