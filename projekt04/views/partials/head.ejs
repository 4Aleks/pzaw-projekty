<!DOCTYPE html>
<html data-theme="<%= app.theme %>" lang="pl">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="container">
<header>
  <nav>
    <a href="/">Start</a>
    <% if (user) { %>
      <span>Witaj, <b><%= user.username %></b></span>
      <% if (user.role === 'admin') { %><span class="admin-badge">ADMIN</span><% } %>
      <a href="/logout">Wyloguj</a>
    <% } else { %>
      <a href="/login">Zaloguj</a>
      <a href="/register">Rejestracja</a>
    <% } %>
  </nav>
  <a href="/settings/toggle-theme?next=<%= encodeURIComponent(page) %>"> Motyw</a>
</header>